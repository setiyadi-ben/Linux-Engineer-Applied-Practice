# =============================================================================
# L-E-A-P STACK CONFIGURATION
# =============================================================================
# Production-oriented environment configuration
# All services bind to VPN IP by default for network isolation
# =============================================================================

# Network Configuration
VPN_IP=10.20.0.2

# =============================================================================
# APPLICATION PORTS (External Access)
# =============================================================================
# Ports yang di-expose ke host untuk external access
# Format: ${VPN_IP}:${HOST_PORT}:${CONTAINER_PORT}
#
APACHE_SSL_PORT=443          # Apache HTTPS endpoint (external)
TOMCAT_SSL_PORT=8443         # Tomcat Manager direct access (VPN-only)

# =============================================================================
# MONITORING PORTS (Optional Direct Access)
# =============================================================================
# Default: Monitoring services accessible via Apache reverse proxy
# Uncomment port bindings in docker-compose.monitoring.yml for direct access
#
# Grafana:      https://${VPN_IP}/grafana (reverse proxy - default)
# Prometheus:   https://${VPN_IP}/prometheus (reverse proxy - default)
#
# Direct access ports (if uncommented):
GRAFANA_PORT=3001           # Grafana web UI direct access
PROMETHEUS_PORT=9090        # Prometheus web UI direct access
CADVISOR_PORT=8081          # cAdvisor web UI direct access (internal scraping only)
NODE_EXPORTER_PORT=9100     # Node Exporter metrics endpoint (internal scraping only)

# =============================================================================
# BACKEND PORT REFERENCE (Internal Docker Network Communication)
# =============================================================================
# Port-port yang digunakan untuk komunikasi antar container di backend network.
# Tidak di-expose ke host - hanya accessible via Docker DNS (container_name:port)
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ Service              │ Port  │ Protocol │ Purpose                │
# ├──────────────────────┼───────┼──────────┼────────────────────────┤
# │ MariaDB              │ 3306  │ MySQL    │ Database queries       │
# │ phpMyAdmin           │ 9000  │ FastCGI  │ PHP-FPM processing     │
# │ Tomcat               │ 8443  │ HTTPS    │ Java apps (SSL)        │
# │ Prometheus           │ 9090  │ HTTP     │ Metrics query API      │
# │ Grafana              │ 3000  │ HTTP     │ Dashboard UI           │
# │ cAdvisor             │ 8080  │ HTTP     │ Container metrics      │
# │ Node Exporter        │ 9100  │ HTTP     │ Host metrics           │
# │ Redis                │ 6379  │ Redis    │ cAdvisor cache         │
# └─────────────────────────────────────────────────────────────────┘
#
# Connection Examples:
# - phpMyAdmin → MariaDB:        mysql://l-e-a-p_mysql:3306
# - Apache → phpMyAdmin FPM:     fcgi://l-e-a-p_pma:9000
# - Apache → Tomcat:             https://l-e-a-p_tomcat:8443
# - Apache → Grafana:            http://l-e-a-p_grafana:3000
# - Prometheus → cAdvisor:       http://l-e-a-p_cadvisor:8080/metrics
# - Prometheus → Node Exporter:  http://l-e-a-p_node-exporter:9100/metrics
# - cAdvisor → Redis:            redis://l-e-a-p_redis:6379
#
# Note: Port ini TIDAK PERLU di-expose ke host karena:
# 1. Security: Mengurangi attack surface
# 2. Isolation: Services communicate via internal Docker network only
# 3. Flexibility: Bisa ganti port tanpa break external access
#
# Exception: Tomcat 8443 di-expose ke ${VPN_IP} untuk direct Manager UI access

# =============================================================================
# SECURITY CREDENTIALS
# =============================================================================
MYSQL_ROOT_PASSWORD=root

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
# phpMyAdmin absolute URI (untuk cookie & redirect path)
PMA_ABSOLUTE_URI=https://${VPN_IP}/phpmyadmin

# Grafana root URL (untuk reverse proxy subpath)
# Note: Configured in docker-compose.monitoring.yml via GF_SERVER_ROOT_URL

# =============================================================================
# ACCESS PATTERNS
# =============================================================================
# 
# PRIMARY ACCESS (via Apache HTTPS reverse proxy - VPN only):
# ┌────────────────────────────────────────────────────────────────┐
# │ Service       │ URL                                            │
# ├───────────────┼────────────────────────────────────────────────┤
# │ phpMyAdmin    │ https://10.20.0.2/phpmyadmin                   │
# │ Tomcat Apps   │ https://10.20.0.2/examples                     │
# │               │ https://10.20.0.2/sample                       │
# │               │ https://10.20.0.2/probe                        │
# │ Grafana       │ https://10.20.0.2/grafana                      │
# │ Prometheus    │ https://10.20.0.2/prometheus                   │
# └────────────────────────────────────────────────────────────────┘
#
# DIRECT PORT ACCESS (optional - uncomment port bindings in compose files):
# ┌────────────────────────────────────────────────────────────────┐
# │ Service       │ URL                                            │
# ├───────────────┼────────────────────────────────────────────────┤
# │ Tomcat Mgr    │ https://10.20.0.2:8443 (already exposed)      │
# │ Grafana       │ http://10.20.0.2:3001 (if uncommented)        │
# │ Prometheus    │ http://10.20.0.2:9090 (if uncommented)        │
# └────────────────────────────────────────────────────────────────┘
#
# INTERNAL ONLY (metrics scrapers - NOT exposed via Apache):
# ┌────────────────────────────────────────────────────────────────┐
# │ cAdvisor      │ http://l-e-a-p_cadvisor:8080                   │
# │               │ (scraped by Prometheus internally)             │
# │ Node Exporter │ http://l-e-a-p_node-exporter:9100              │
# │               │ (scraped by Prometheus internally)             │
# └────────────────────────────────────────────────────────────────┘
#
# Why cAdvisor & Node Exporter not exposed via Apache?
# - Prometheus scrapes them directly via backend network
# - No need for external access - metrics viewing happens via Grafana
# - Reduces attack surface (fewer exposed endpoints)
# - Prometheus has direct access to raw metrics endpoints

# =============================================================================
# CONFIGURATION EXAMPLES
# =============================================================================
#
# Change VPN IP:
#   1. Edit VPN_IP value above
#   2. Update PMA_ABSOLUTE_URI if changed
#   3. Run: docker compose down && docker compose up -d
#
# Enable direct access to monitoring services:
#   1. Edit docker-compose.monitoring.yml
#   2. Uncomment port binding for desired service (e.g., Grafana, Prometheus)
#   3. Run: docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up -d --force-recreate <service>
#
# Change monitoring port:
#   1. Edit port value above (e.g., GRAFANA_PORT=3001)
#   2. Uncomment port binding in docker-compose.monitoring.yml
#   3. Run: docker compose up -d --force-recreate <service>
#
# =============================================================================